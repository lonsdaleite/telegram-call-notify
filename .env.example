# Telegram API credentials: https://my.telegram.org
TG_API_ID=
TG_API_HASH=

# Session file name or absolute path (relative paths are resolved from main.py directory)
TG_SESSION=userbot

# ntfy endpoint (required in production)
NTFY_URL=https://ntfy.example.com/calls

# Optional Bearer token for ntfy
NTFY_TOKEN=

# Notification settings
NOTIFY_COUNT=3
NOTIFY_INTERVAL=5
NTFY_PRIORITY=high

# Set to true for local debug (no ntfy requests)
DEBUG=false
